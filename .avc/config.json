{
  "schemaVersion": "1",
  "securityLevel": "redacted",
  "eventPersistence": {
    "failClosed": true,
    "allowedSecurityLevels": [
      "full",
      "redacted",
      "summary_only"
    ]
  },
  "lifecycle": {
    "immutableEvents": true
  },
  "policy": {
    "requireGatesBeforeApprove": true,
    "requireGatesBeforeMerge": true,
    "requireRollbackMetadataForRiskTiers": [
      "high"
    ]
  },
  "runtime": {
    "defaultMode": "ledger-first",
    "allowFallbackMode": false
  }
}
